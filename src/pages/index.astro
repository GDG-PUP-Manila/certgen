---
import Layout from '../layouts/Layout.astro';
import eventsData from '../../data/event.json';
import surveysData from '../../data/survey.json';

// Type inference to ensure safety
type Event = {
  id: string;
  title: string;
  description: string;
  venue: string;
  start_date: string;
};

// Filter out past events if needed, for MVP we just show all
const events: Event[] = eventsData;
---

<Layout 
  title="GDG PUP Manila | Event Surveys & Certificates"
  description="Evaluate official GDG PUP Manila events, submit your feedback, and instantly generate your personalized certificate of participation."
>
  <section class="relative mx-auto grid w-full max-w-7xl content-start gap-10 overflow-hidden px-4 text-center py-16 md:py-24 animate-[fade-in_650ms_cubic-bezier(0.2,0.8,0.2,1)_both]">
    
    <div class="relative z-10 flex flex-col items-center">
      <h1 class="m-0 leading-[1.1] tracking-[-0.04em] text-[#202124] mb-6">
        <span class="block text-[clamp(2.5rem,6vw,5rem)] font-black uppercase text-slate-900">Event</span>
        <span class="relative block text-[clamp(2.5rem,6vw,5rem)] font-black uppercase text-[#4285f4]">
          Surveys
        </span>
      </h1>
      <p class="m-0 max-w-2xl text-[clamp(1.1rem,2vw,1.25rem)] text-gray-700 mx-auto px-4">
        Share your experience, provide feedback, and securely download your official certificate of participation.
      </p>
    </div>

  </section>

  <section class="relative mx-auto w-full max-w-7xl px-4 pb-24">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {events.map((event, idx) => {
        const dateObj = new Date(event.start_date);
        const dateString = dateObj.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
        
        // Find the mapped survey config
        const survey = surveysData.find((s: any) => s.event_id === event.id);
        const urlSlug = survey ? survey.slug : event.id;

        return (
          <a
            href={`/survey/${urlSlug}`}
            class={`group flex flex-col rounded-3xl border border-gray-200 bg-white p-6 no-underline shadow-[0_12px_30px_rgba(17,24,39,0.06)] transition-all duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-1 hover:shadow-[0_18px_36px_rgba(17,24,39,0.12)] animate-[fade-in_${600+idx*100}ms_cubic-bezier(0.2,0.8,0.2,1)_both]`}
          >
            <div class="mb-4 inline-flex self-start rounded-full bg-blue-50 px-3 py-1 text-xs font-bold text-[#4285f4] uppercase tracking-wider">
              {dateString}
            </div>
            <h2 class="m-0 text-2xl font-black tracking-tight text-slate-900 line-clamp-2 leading-tight mb-3">
              {event.title}
            </h2>
            <p class="m-0 text-sm text-gray-600 line-clamp-3 mb-6 flex-grow">
              {event.description}
            </p>
            <div class="mt-auto w-full inline-flex items-center justify-center rounded-2xl bg-[#4285f4] px-4 py-3 text-sm font-bold text-white shadow-[0_8px_20px_rgba(66,133,244,0.2)] transition-colors group-hover:bg-[#3367d6]">
              Take Survey
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
